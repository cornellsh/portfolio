---
import Analytics from '@vercel/analytics/astro';
import '@fontsource-variable/public-sans/wght.css';
import '@fontsource/manrope/latin-500.css';
import '@fontsource/manrope/latin-600.css';
import '@fontsource/manrope/latin-ext-500.css';
import '@fontsource/manrope/latin-ext-600.css';
import '@fontsource/manrope/cyrillic-400.css';
import '@fontsource/manrope/cyrillic-500.css';
import '@fontsource/manrope/cyrillic-600.css';
import '@fontsource/manrope/cyrillic-700.css';
import '../styles/global.css';
import { siteUrl } from '../data/portfolio';

// Font preload URLs — Vite resolves these to hashed /_astro/*.woff2 paths at build time.
// We preload only the subsets required to render the above-the-fold LCP text.
import publicSansLatin from '@fontsource-variable/public-sans/files/public-sans-latin-wght-normal.woff2?url';
import publicSansLatinExt from '@fontsource-variable/public-sans/files/public-sans-latin-ext-wght-normal.woff2?url';
import manropeLatin600 from '@fontsource/manrope/files/manrope-latin-600-normal.woff2?url';
import manropeLatinExt600 from '@fontsource/manrope/files/manrope-latin-ext-600-normal.woff2?url';
import manropeCyrillic600 from '@fontsource/manrope/files/manrope-cyrillic-600-normal.woff2?url';

type PageType = 'website' | 'article' | 'blog' | 'profile';

interface Props {
  lang?: string;
  title: string;
  description: string;
  siteName?: string;
  canonicalUrl?: string;
  ogLocale?: string;
  pageType?: PageType;
  articleMetadata?: {
    publishedTime: string;
    modifiedTime?: string;
    section?: string;
  };
  extraStructuredData?: Record<string, unknown>[];
  socialImage?: string;
  alternateLinks?: Array<{
    hrefLang: string;
    href: string;
  }>;
  ogAlternateLocales?: string[];
}

const {
  lang = 'en',
  title,
  description,
  siteName = 'Cornell Shakh',
  canonicalUrl = siteUrl,
  ogLocale = 'en_US',
  pageType = 'website',
  articleMetadata,
  extraStructuredData = [],
  socialImage,
  alternateLinks = [],
  ogAlternateLocales = [],
} = Astro.props;
const socialImageUrl = socialImage ? `${siteUrl}${socialImage}` : `${siteUrl}/og-image.png`;
const socialImageAlt = 'Cornell Shakh social preview card';
const pageTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

// Pick font subsets to preload based on the rendered language.
// - Latin (default): Public Sans body + Manrope 600 display
// - Czech (cs): add latin-ext
// - Ukrainian (uk) / Russian (ru): swap latin-ext for cyrillic on Manrope
const langPrefix = lang.toLowerCase().slice(0, 2);
const usesCyrillic = langPrefix === 'uk' || langPrefix === 'ru';
const usesLatinExt = langPrefix === 'cs';
const fontPreloads = [
  publicSansLatin,
  manropeLatin600,
  usesLatinExt ? publicSansLatinExt : null,
  usesLatinExt ? manropeLatinExt600 : null,
  usesCyrillic ? manropeCyrillic600 : null,
].filter((href): href is string => Boolean(href));

const schemaType =
  pageType === 'article'
    ? 'Article'
    : pageType === 'blog'
    ? 'CollectionPage'
    : pageType === 'profile'
    ? 'ProfilePage'
    : 'WebPage';

const webPageNode: Record<string, unknown> = {
  '@type': schemaType,
  '@id': `${canonicalUrl}#webpage`,
  name: pageTitle,
  url: canonicalUrl,
  description,
  inLanguage: lang,
  isPartOf: { '@id': `${siteUrl}/#website` },
  primaryImageOfPage: { '@id': `${siteUrl}/#primaryimage` },
};

if (pageType === 'article' && articleMetadata) {
  webPageNode.datePublished = articleMetadata.publishedTime;
  if (articleMetadata.modifiedTime) webPageNode.dateModified = articleMetadata.modifiedTime;
  webPageNode.author = { '@id': `${siteUrl}/#person` };
  webPageNode.mainEntityOfPage = canonicalUrl;
}

if (pageType !== 'article') {
  webPageNode.about = { '@id': `${siteUrl}/#person` };
}

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    webPageNode,
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: siteUrl,
      name: siteName,
      description,
      inLanguage: lang,
      publisher: { '@id': `${siteUrl}/#person` },
    },
    {
      '@type': 'ImageObject',
      '@id': `${siteUrl}/#primaryimage`,
      url: socialImageUrl,
      width: 1200,
      height: 630,
      caption: socialImageAlt,
      inLanguage: lang,
    },
    {
      '@type': 'Person',
      '@id': `${siteUrl}/#person`,
      name: 'Cornell Shakh',
      url: siteUrl,
      image: { '@id': `${siteUrl}/#primaryimage` },
      email: 'mailto:cornellshakh@proton.me',
      jobTitle: 'Full-Stack Engineer',
      description,
      sameAs: ['https://github.com/cornellsh'],
    },
    ...extraStructuredData,
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://va.vercel-scripts.com" crossorigin />
    {fontPreloads.map((href) => (
      <link rel="preload" as="font" type="font/woff2" href={href} crossorigin />
    ))}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${siteName} — Blog`} href="/rss.xml" />
    {alternateLinks.length > 0 ? <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} /> : null}
    {alternateLinks.map((link) => <link rel="alternate" hreflang={link.hrefLang} href={link.href} />)}
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="description" content={description} />
    <meta name="author" content="Cornell Shakh" />
    <meta name="application-name" content={siteName} />
    <meta name="apple-mobile-web-app-title" content={siteName} />
    <meta name="theme-color" content="#fafafa" />
    <meta name="color-scheme" content="light" />
    <meta property="og:type" content={pageType === 'article' ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />
    {ogAlternateLocales.map((locale) => <meta property="og:locale:alternate" content={locale} />)}
    {pageType === 'article' && articleMetadata ? <meta property="article:published_time" content={articleMetadata.publishedTime} /> : null}
    {pageType === 'article' && articleMetadata?.modifiedTime ? <meta property="article:modified_time" content={articleMetadata.modifiedTime} /> : null}
    {pageType === 'article' && articleMetadata?.section ? <meta property="article:section" content={articleMetadata.section} /> : null}
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:secure_url" content={socialImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
    <Analytics />
  </body>
</html>
