---
import BaseLayout from '../layouts/BaseLayout.astro';
import LucideIcon from '../components/LucideIcon.astro';
import { defaultLocale, getHtmlLang, getOgLocale, siteUrl } from '../data/portfolio';

const locale = defaultLocale;
---

<BaseLayout
  lang={getHtmlLang(locale)}
  title="Page not found | Cornell Shakh"
  description="The page you're looking for doesn't exist."
  canonicalUrl={`${siteUrl}/404`}
  ogLocale={getOgLocale(locale)}
  pageType="website"
>
  <main id="main" class="not-found">
    <div class="not-found__inner">
      <p class="not-found__eyebrow">404</p>
      <h1 class="not-found__title">Page not found</h1>
      <p class="not-found__body">
        The page you're looking for doesn't exist or may have moved.
      </p>
      <div class="not-found__actions">
        <a class="not-found__link" href="/">
          <LucideIcon name="ArrowLeft" class="not-found__icon" />
          <span>Back to portfolio</span>
        </a>
        <a class="not-found__link not-found__link--muted" href="/blog/">
          <span>Read the blog</span>
          <LucideIcon name="ArrowUpRight" class="not-found__icon" />
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 48px 24px;
  }

  .not-found__inner {
    max-width: 520px;
    text-align: left;
  }

  .not-found__eyebrow {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .not-found__title {
    margin: 14px 0 18px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-xl);
    line-height: 0.96;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  .not-found__body {
    margin: 0 0 32px;
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--text-muted);
    max-width: 38ch;
  }

  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
  }

  .not-found__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-weight: 500;
    transition: background var(--transition), border-color var(--transition), transform var(--transition);
  }

  .not-found__link:hover,
  .not-found__link:focus-visible {
    background: var(--hover-bg);
    border-color: var(--hover-border);
  }

  .not-found__link--muted {
    border-color: var(--border);
    color: var(--text-muted);
  }

  .not-found__icon {
    width: 16px;
    height: 16px;
  }

  @media (max-width: 520px) {
    .not-found__title {
      font-size: 2.25rem;
    }
  }
</style>
