---
import HomePage from '../../components/HomePage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  defaultLocale,
  getHtmlLang,
  getLocalePath,
  getOgLocale,
  getPortfolioContent,
  localeMeta,
  locales,
  type Locale,
} from '../../data/portfolio';

export const getStaticPaths = () =>
  locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));

const locale = Astro.params.locale as Locale;
const content = getPortfolioContent(locale);
const siteUrl = 'https://cornell.sh';
const canonicalUrl = `${siteUrl}${getLocalePath(locale)}`;
const alternateLinks = locales.map((item) => ({
  hrefLang: localeMeta[item].hrefLang,
  href: `${siteUrl}${getLocalePath(item)}`,
}));
---

<BaseLayout
  lang={getHtmlLang(locale)}
  title={content.seo.title}
  description={content.seo.description}
  siteName={content.seo.siteName}
  canonicalUrl={canonicalUrl}
  ogLocale={getOgLocale(locale)}
  alternateLinks={alternateLinks}
>
  <HomePage locale={locale} content={content} />
</BaseLayout>
