---
import HomePage from '../../components/HomePage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getRecentBlogPosts } from '../../data/blog';
import { defaultLocale, getHomePageMeta, isLocale, locales } from '../../data/portfolio';

export const getStaticPaths = () =>
  locales
    .filter((locale) => locale !== defaultLocale)
    .map((locale) => ({ params: { locale } }));

if (!isLocale(Astro.params.locale)) {
  // Should never happen — getStaticPaths constrains the universe — but if a
  // future refactor breaks that invariant, fail loud at build time instead
  // of letting `getPortfolioContent(undefined)` crash with a less obvious
  // error deeper in the render.
  throw new Error(`Unknown locale param: ${String(Astro.params.locale)}`);
}

const meta = getHomePageMeta(Astro.params.locale);
const blogPosts = await getRecentBlogPosts(3);
---

<BaseLayout
  lang={meta.lang}
  title={meta.title}
  description={meta.description}
  siteName={meta.siteName}
  canonicalUrl={meta.canonicalUrl}
  ogLocale={meta.ogLocale}
  pageType="profile"
  alternateLinks={meta.alternateLinks}
  ogAlternateLocales={meta.ogAlternateLocales}
>
  <HomePage locale={meta.locale} content={meta.content} blogPosts={blogPosts} />
</BaseLayout>
