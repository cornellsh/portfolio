---
import { getCollection } from 'astro:content';
import HomePage from '../components/HomePage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  defaultLocale,
  getHtmlLang,
  getLocalePath,
  getOgLocale,
  getPortfolioContent,
  localeMeta,
  locales,
} from '../data/portfolio';

const locale = defaultLocale;
const content = getPortfolioContent(locale);
const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
const siteUrl = 'https://cornell.sh';
const canonicalUrl = `${siteUrl}${getLocalePath(locale)}`;
const alternateLinks = locales.map((item) => ({
  hrefLang: localeMeta[item].hrefLang,
  href: `${siteUrl}${getLocalePath(item)}`,
}));
---

<BaseLayout
  lang={getHtmlLang(locale)}
  title={content.seo.title}
  description={content.seo.description}
  siteName={content.seo.siteName}
  canonicalUrl={canonicalUrl}
  ogLocale={getOgLocale(locale)}
  alternateLinks={alternateLinks}
>
  <HomePage locale={locale} content={content} blogPosts={blogPosts} />
</BaseLayout>
