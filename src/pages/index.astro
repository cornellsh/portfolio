---
import HomePage from '../components/HomePage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getRecentBlogPosts } from '../data/blog';
import { defaultLocale, getHomePageMeta } from '../data/portfolio';

const meta = getHomePageMeta(defaultLocale);
const blogPosts = await getRecentBlogPosts(3);
---

<BaseLayout
  lang={meta.lang}
  title={meta.title}
  description={meta.description}
  siteName={meta.siteName}
  canonicalUrl={meta.canonicalUrl}
  ogLocale={meta.ogLocale}
  pageType="profile"
  alternateLinks={meta.alternateLinks}
  ogAlternateLocales={meta.ogAlternateLocales}
>
  <HomePage locale={meta.locale} content={meta.content} blogPosts={blogPosts} />
</BaseLayout>
