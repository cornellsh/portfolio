---
import ProjectCard from '../components/ProjectCard.astro';
import Sidebar from '../components/Sidebar.astro';
import LucideIcon from '../components/LucideIcon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLocale, getPortfolioContent } from '../data/portfolio';

const splitPeriod = (period: string) => period.split('\u2013').map((part) => part.trim());
const locale = defaultLocale;
const content = getPortfolioContent(locale);
---

<BaseLayout
  lang={locale}
  title={content.seo.title}
  description={content.seo.description}
>
  <div id="top"></div>
  <div class="shell">
    <main class="page">
      <Sidebar
        profile={content.profile}
        links={content.links}
        sections={content.sections}
        languageLabel={content.headings.language}
        currentLocale={locale}
      />

      <div class="content">
        <section class="content-section intro-section" id="intro" data-section data-reveal>
          {content.profile.intro.map((paragraph) => (
            <p class="intro-copy intro-text">
              {paragraph}
            </p>
          ))}
        </section>

        <section class="content-section experience-list" id="experience" data-section data-reveal>
          <div class="section-header">
            <h2 class="section-heading">{content.headings.experience}</h2>
          </div>

          {content.experience.map((item) => (
            <article class="experience-item" data-reveal>
              <p class="experience-item__meta">
                <span>{splitPeriod(item.period)[0]}</span>
                <span class="experience-item__meta-separator" aria-hidden="true">–</span>
                <span>{splitPeriod(item.period)[1]}</span>
              </p>
              <div class="experience-item__content">
                <h3>
                  <span>{item.role}</span>
                  <span class="experience-item__separator" aria-hidden="true">•</span>
                  <span>{item.organization}</span>
                </h3>
                <p>{item.summary}</p>
                <ul class="badge-list" aria-label={`${item.role} technologies`}>
                  {item.stack.map((tech) => (
                    <li>{tech}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </section>

        <section class="content-section" id="projects" data-section data-reveal>
          <div class="section-header">
            <h2 class="section-heading">{content.headings.projects}</h2>
          </div>

          <div class="project-list">
            {content.projects.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>

          <div class="section-actions">
            <a class="text-button" href="#top">
              <LucideIcon name="ArrowUp" />
              <span>Back to top</span>
            </a>
          </div>
        </section>

      </div>
    </main>
  </div>

  <script is:inline>
    const sections = [...document.querySelectorAll('[data-section]')];
    const links = [...document.querySelectorAll('[data-section-link]')];
    const revealItems = [...document.querySelectorAll('[data-reveal]')];
    const languageDropdown = document.querySelector('.sidebar__language-dropdown');

    const setActiveLink = (id) => {
      links.forEach((link) => {
        const isCurrent = link.dataset.target === id;
        link.setAttribute('aria-current', isCurrent ? 'true' : 'false');
      });
    };

    const updateActiveSection = () => {
      const marker = window.scrollY + window.innerHeight * 0.28;
      let activeSection = sections[0];

      for (const section of sections) {
        if (section.offsetTop <= marker) {
          activeSection = section;
        }
      }

      const nearBottom = window.innerHeight + window.scrollY >= document.body.offsetHeight - 24;

      if (nearBottom) {
        activeSection = sections.at(-1) ?? activeSection;
      }

      if (activeSection?.id) {
        setActiveLink(activeSection.id);
      }
    };

    updateActiveSection();
    window.addEventListener('scroll', updateActiveSection, { passive: true });
    window.addEventListener('resize', updateActiveSection);

    document.addEventListener('click', (event) => {
      if (!languageDropdown?.hasAttribute('open')) {
        return;
      }

      if (!languageDropdown.contains(event.target)) {
        languageDropdown.removeAttribute('open');
      }
    });

    revealItems.forEach((item, index) => {
      item.style.setProperty('--reveal-delay', `${Math.min(index * 45, 180)}ms`);
    });

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
    } else {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        {
          rootMargin: '0px 0px -8% 0px',
          threshold: 0.06,
        },
      );

      revealItems.forEach((item) => revealObserver.observe(item));
    }
  </script>
</BaseLayout>
