---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import LucideIcon from '../../components/LucideIcon.astro';
import { getPortfolioContent, siteUrl } from '../../data/portfolio';

export const getStaticPaths = async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
};

const { post } = Astro.props;
const { Content, headings } = await render(post);
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const content = getPortfolioContent('en');
const canonicalUrl = `${siteUrl}/blog/${post.id}/`;
const formatter = new Intl.DateTimeFormat('en', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const articleMetadata = {
  publishedTime: post.data.publishedAt.toISOString(),
  modifiedTime: post.data.updatedAt?.toISOString(),
  section: 'Blog',
};

const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${canonicalUrl}#blogposting`,
  headline: post.data.title,
  description: post.data.description,
  author: { '@id': `${siteUrl}/#person` },
  publisher: { '@id': `${siteUrl}/#person` },
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: (post.data.updatedAt ?? post.data.publishedAt).toISOString(),
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  image: post.data.ogImage ? `${siteUrl}${post.data.ogImage}` : `${siteUrl}/og-image.png`,
  inLanguage: 'en',
};

const breadcrumbList = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog/` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: canonicalUrl },
  ],
};
---

<BaseLayout
  lang="en"
  title={post.data.title}
  description={post.data.description}
  siteName={content.seo.siteName}
  canonicalUrl={canonicalUrl}
  ogLocale="en_US"
  pageType="article"
  articleMetadata={articleMetadata}
  extraStructuredData={[blogPosting, breadcrumbList]}
  socialImage={post.data.ogImage}
>
  <div id="top"></div>
  <div class="shell blog-article-shell">
    <main id="main" class="page blog-article-layout">
      {toc.length > 0 && (
        <nav class="article-toc" aria-label="Table of contents">
          <div class="article-toc__container">
            <p class="article-toc__title">Heading Navigator</p>
            <ul class="article-toc__list">
              {toc.map((heading) => (
                <li class={`article-toc__item article-toc__item--h${heading.depth}`}>
                  <a
                    href={`#${heading.slug}`}
                    class="article-toc__link"
                    data-toc-link
                    data-target={heading.slug}
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </nav>
      )}
      <div class="content blog-article-content">
        <article class="content-section article-page">
          <div class="blog-author-block">
            <Sidebar
              profile={content.profile}
              links={[]}
              languageLabel={content.headings.language}
              currentLocale="en"
              copyEmailLabel={content.headings.copyEmail}
              openEmailLabel={content.headings.openEmail}
              utilityItems={[{ href: '/blog/', label: 'Back to blog', iconName: 'ArrowLeft' }]}
              primaryIdentity={false}
            />
          </div>

          <header class="article-header">
            <p class="article-meta">
              <span>{formatter.format(post.data.publishedAt)}</span>
              {post.data.updatedAt ? (
                <>
                  <span class="article-meta__separator" aria-hidden="true">•</span>
                  <span>Updated {formatter.format(post.data.updatedAt)}</span>
                </>
              ) : null}
            </p>
            <h1 class="section-heading article-title">{post.data.title}</h1>
            <p class="article-dek">{post.data.description}</p>
          </header>

          <div class="article-prose">
            <Content />
          </div>

          <div class="section-actions section-actions--start">
            <a class="text-button" href="#top">
              <LucideIcon name="ArrowUp" />
              <span>{content.headings.backToTop}</span>
            </a>
          </div>
        </article>
      </div>
    </main>
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const tocLinks = [...document.querySelectorAll('[data-toc-link]')];
    if (tocLinks.length === 0) return;
    const headings = [...document.querySelectorAll('.article-prose h2, .article-prose h3')].filter((h) => h.id);
    if (headings.length === 0) return;

    const setActive = (id) => {
      tocLinks.forEach((link) => {
        link.setAttribute('aria-current', link.dataset.target === id ? 'true' : 'false');
      });
    };

    if ('IntersectionObserver' in window) {
      const visible = new Map();
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) visible.set(entry.target.id, entry.intersectionRatio);
            else visible.delete(entry.target.id);
          }
          if (visible.size === 0) return;
          // pick the top-most currently intersecting heading
          const firstVisible = headings.find((h) => visible.has(h.id));
          if (firstVisible) setActive(firstVisible.id);
        },
        { rootMargin: '-20% 0px -70% 0px', threshold: [0, 1] },
      );
      headings.forEach((h) => io.observe(h));
    } else {
      const update = () => {
        const marker = window.scrollY + window.innerHeight * 0.28;
        let active = null;
        for (const h of headings) {
          if (h.offsetTop <= marker) active = h;
        }
        if (active) setActive(active.id);
      };
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update, { passive: true });
    }
  })();
</script>
