---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getPortfolioContent } from '../../data/portfolio';

const content = getPortfolioContent('en');
const siteUrl = 'https://cornell.sh';
const canonicalUrl = `${siteUrl}/blog/`;
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<BaseLayout
  lang="en"
  title="Blog"
  description="Notes on building products, internal tools, software design, and the lessons that come from shipping real work."
  siteName={content.seo.siteName}
  canonicalUrl={canonicalUrl}
  ogLocale="en_US"
>
  <div class="shell">
    <main class="page blog-index-layout">
      <Sidebar
        profile={content.profile}
        links={[]}
        languageLabel={content.headings.language}
        currentLocale="en"
        copyEmailLabel={content.headings.copyEmail}
        openEmailLabel={content.headings.openEmail}
        utilityItems={[{ href: '/', label: 'Back to portfolio', iconName: 'ArrowLeft' }]}
      />

      <div class="content">
        <section class="content-section blog-index-section">
          <div class="section-header">
            <h1 class="section-heading">Blog.</h1>
          </div>

          <div class="blog-post-list">
            {posts.map((post) => <BlogPostCard post={post} />)}
          </div>
        </section>
      </div>
    </main>
  </div>
</BaseLayout>
