---
import LucideIcon from './LucideIcon.astro';
import type { ProjectItem } from '../data/portfolio';

interface Props {
  project: ProjectItem;
}

const { project } = Astro.props;
const isExternalHref = (href: string) => href.startsWith('http://') || href.startsWith('https://');
const hasActiveHref = (href: string) => href.trim() !== '' && href !== '#';
const hasWebsiteLink = hasActiveHref(project.websiteHref);
const visibleLinks = project.links.filter((link) => hasActiveHref(link.href));
---

<article class="project-card">
  {
    project.image ? (
      hasWebsiteLink ? (
        <a
          class="project-card__media"
          href={project.websiteHref}
          target={isExternalHref(project.websiteHref) ? '_blank' : undefined}
          rel={isExternalHref(project.websiteHref) ? 'noopener noreferrer' : undefined}
          aria-label={`${project.name} website`}
          draggable="false"
        >
          <img src={project.image} alt="" width="92" height="92" loading="lazy" decoding="async" draggable="false" />
        </a>
      ) : (
        <div class="project-card__media" aria-hidden="true">
          <img src={project.image} alt="" width="92" height="92" loading="lazy" decoding="async" draggable="false" />
        </div>
      )
    ) : null
  }

  <div class="project-card__content">
    <div class="project-card__header">
      <div>
        <div class="project-card__title-row">
          <h3>
            {hasWebsiteLink ? (
              <a
                class="project-card__title-anchor"
                href={project.websiteHref}
                target={isExternalHref(project.websiteHref) ? '_blank' : undefined}
                rel={isExternalHref(project.websiteHref) ? 'noopener noreferrer' : undefined}
              >
                <span>{project.name}</span>
                <LucideIcon name="ArrowUpRight" />
              </a>
            ) : (
              <span>{project.name}</span>
            )}
          </h3>
        </div>
      </div>
    </div>

    <p>{project.summary}</p>

    {visibleLinks.length > 0 ? (
      <ul class="project-card__links" aria-label={`${project.name} links`}>
        {visibleLinks.map((link) => (
          <li>
            <a
              class="project-card__secondary-link"
              href={link.href}
              target={isExternalHref(link.href) ? '_blank' : undefined}
              rel={isExternalHref(link.href) ? 'noopener noreferrer' : undefined}
            >
              <LucideIcon name="Link" />
              <span>{link.label}</span>
            </a>
          </li>
        ))}
      </ul>
    ) : null}

    <ul class="badge-list" aria-label={`${project.name} technologies`}>
      {project.stack.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>
</article>
