---
import LucideIcon from './LucideIcon.astro';
import type { ProjectItem } from '../data/portfolio';

interface Props {
  project: ProjectItem;
}

const { project } = Astro.props;
const isExternalHref = (href: string) => href.startsWith('http://') || href.startsWith('https://');
---

<article class="project-card">
  {
    project.image ? (
      <a
        class="project-card__media"
        href={project.websiteHref}
        target={isExternalHref(project.websiteHref) ? '_blank' : undefined}
        rel={isExternalHref(project.websiteHref) ? 'noreferrer' : undefined}
        aria-label={`${project.name} website`}
        draggable="false"
        ondragstart="return false;"
      >
        <img src={project.image} alt="" loading="lazy" decoding="async" draggable="false" />
      </a>
    ) : null
  }

  <div class="project-card__content">
    <div class="project-card__header">
      <div>
        <div class="project-card__title-row">
          <h3>
            <a
              class="project-card__title-anchor"
              href={project.websiteHref}
              target={isExternalHref(project.websiteHref) ? '_blank' : undefined}
              rel={isExternalHref(project.websiteHref) ? 'noreferrer' : undefined}
            >
              <span>{project.name}</span>
              <LucideIcon name="ArrowUpRight" />
            </a>
          </h3>
        </div>
      </div>
    </div>

    <p>{project.summary}</p>

    {project.links.length > 0 ? (
      <ul class="project-card__links" aria-label={`${project.name} links`}>
            {project.links.map((link) => (
              <li>
                <a
                  class="project-card__secondary-link"
                  href={link.href}
                  target={isExternalHref(link.href) ? '_blank' : undefined}
                  rel={isExternalHref(link.href) ? 'noreferrer' : undefined}
                >
                  <LucideIcon name="Link" />
                  <span>{link.label}</span>
                </a>
              </li>
        ))}
      </ul>
    ) : null}

    <ul class="badge-list" aria-label={`${project.name} technologies`}>
      {project.stack.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>
</article>
