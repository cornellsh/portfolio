---
type IconName = 'ArrowUp' | 'ArrowUpRight' | 'ArrowUpLeft' | 'ArrowLeft' | 'Link' | 'Copy' | 'Sun' | 'Moon' | 'Monitor';

interface Props {
  name: IconName;
  class?: string;
}

const { name, class: className } = Astro.props;

const iconPaths: Record<IconName, string> = {
  ArrowUp: '<path d="m5 12 7-7 7 7" /><path d="M12 19V5" />',
  ArrowUpRight: '<path d="M7 7h10v10" /><path d="M7 17 17 7" />',
  ArrowUpLeft: '<path d="M7 17V7h10" /><path d="M17 17 7 7" />',
  ArrowLeft: '<path d="m12 19-7-7 7-7" /><path d="M19 12H5" />',
  Link: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" /><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />',
  Copy: '<rect width="14" height="14" x="8" y="8" rx="2" ry="2" /><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />',
  Sun: '<circle cx="12" cy="12" r="4" /><path d="M12 2v2" /><path d="M12 20v2" /><path d="m4.93 4.93 1.41 1.41" /><path d="m17.66 17.66 1.41 1.41" /><path d="M2 12h2" /><path d="M20 12h2" /><path d="m6.34 17.66-1.41 1.41" /><path d="m19.07 4.93-1.41 1.41" />',
  Moon: '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />',
  Monitor: '<rect width="20" height="14" x="2" y="3" rx="2" /><line x1="8" x2="16" y1="21" y2="21" /><line x1="12" x2="12" y1="17" y2="21" />',
};

const iconMarkup = iconPaths[name];

if (!iconMarkup) {
  throw new Error(`LucideIcon: unknown icon "${name}"`);
}
---

<svg
  aria-hidden="true"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  set:html={iconMarkup}
/>
