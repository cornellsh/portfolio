---
import LucideIcon from './LucideIcon.astro';
import LinkIcon from './LinkIcon.astro';
import { getLocalePath, languageOptions } from '../data/portfolio';
import type { LinkItem, PortfolioContent, SectionItem, Locale } from '../data/portfolio';
import type { CollectionEntry } from 'astro:content';

type NavItem = {
  href: string;
  label: string;
  targetId?: string;
  alwaysMarked?: boolean;
};

type UtilityItem = {
  href: string;
  label: string;
  iconName: 'ArrowUpLeft' | 'ArrowLeft' | 'ArrowUpRight';
};

interface Props {
  profile: PortfolioContent['profile'];
  links: LinkItem[];
  sections?: SectionItem[];
  languageLabel: string;
  currentLocale: Locale;
  copyEmailLabel?: string;
  openEmailLabel?: string;
  navItems?: NavItem[];
  navLabel?: string;
  blogPosts?: CollectionEntry<'blog'>[];
  utilityItems?: UtilityItem[];
  /** If false, renders the profile name as a non-h1 element (for secondary pages). */
  primaryIdentity?: boolean;
}

const {
  profile,
  links,
  sections = [],
  languageLabel,
  currentLocale,
  copyEmailLabel = 'Copy',
  openEmailLabel = 'Open mail app',
  navItems,
  navLabel = 'Section index',
  blogPosts = [],
  utilityItems = [],
  primaryIdentity = true,
} = Astro.props;
const emailLink = links.find((link) => link.type === 'email');
const isExternalHref = (href: string) => href.startsWith('http://') || href.startsWith('https://');
const opensInNewTab = (href: string) => isExternalHref(href) || href.toLowerCase().endsWith('.pdf');
const hasActiveHref = (href: string) => href.trim() !== '' && href !== '#';
const visibleLinks = links.filter((link) => link.type === 'email' || hasActiveHref(link.href));
const resolvedNavItems = navItems ?? sections.map((section) => ({ href: `#${section.id}`, label: section.label, targetId: section.id }));
---

<aside class="sidebar" aria-label="Profile and site navigation">
  <div class="sidebar__intro">
    <div class="sidebar__identity">
      {primaryIdentity ? <h1>{profile.name}</h1> : <p class="sidebar__identity-name">{profile.name}</p>}
      <img
        class="sidebar__brand-mark"
        src="/brand-mark.svg"
        alt=""
        aria-hidden="true"
        width="45"
        height="45"
        loading="eager"
        decoding="async"
        draggable="false"
      />
    </div>
    {primaryIdentity ? <h2 class="sidebar__role">{profile.role}</h2> : <p class="sidebar__role">{profile.role}</p>}
    <p class="sidebar__summary">{profile.summary}</p>
  </div>

  {resolvedNavItems.length > 0 ? (
    <nav class="sidebar__nav" aria-label={navLabel}>
      <ul>
        {resolvedNavItems.map((item, index) => (
        <li>
          <a
            href={item.href}
            data-section-link={item.targetId ? true : undefined}
            data-target={item.targetId}
            aria-current={index === 0 && item.targetId ? 'true' : undefined}
            data-always-marked={item.alwaysMarked ? 'true' : undefined}
          >
            {item.label}
          </a>
        </li>
        ))}
      </ul>
    </nav>
  ) : null}

  <div class="sidebar__utility">
    <ul class="sidebar__links" aria-label="External links">
      {utilityItems.length > 0
        ? utilityItems.map((item) => (
        <li>
          <a href={item.href} class:list={['sidebar__utility-link', item.iconName === 'ArrowLeft' && 'sidebar__utility-link--back']}>
            <span class="sidebar__link-icon" aria-hidden="true">
              <LucideIcon name={item.iconName} />
            </span>
            <span class="sidebar__link-label">{item.label}</span>
          </a>
        </li>
          ))
        : visibleLinks.map((link) => (
        <li>
          {link.type === 'email' ? (
            <button
              type="button"
              class="sidebar__link-button"
              data-open-email-dialog
              aria-haspopup="dialog"
              aria-controls="email-dialog"
            >
              <span class="sidebar__link-icon" aria-hidden="true">
                <LinkIcon type={link.type} />
              </span>
              <span class="sidebar__link-label">{link.label}</span>
            </button>
          ) : (
            <a href={link.href} target={opensInNewTab(link.href) ? '_blank' : undefined} rel={opensInNewTab(link.href) ? 'noopener noreferrer' : undefined}>
              <span class="sidebar__link-icon" aria-hidden="true">
                <LinkIcon type={link.type} />
              </span>
              <span class="sidebar__link-label">{link.label}</span>
            </a>
          )}
        </li>
          ))}
      {blogPosts.length > 0 && utilityItems.length === 0 ? (
        <li>
          <a href="/blog/">
            <span class="sidebar__link-icon" aria-hidden="true">
              <LinkIcon type="blog" />
            </span>
            <span class="sidebar__link-label">Blog</span>
          </a>
        </li>
      ) : null}
    </ul>

    {emailLink ? (
      <dialog id="email-dialog" class="email-dialog" data-email-dialog aria-label="Email options">
        <button type="button" class="email-dialog__close" data-close-email-dialog aria-label="Close email dialog">
          <span aria-hidden="true">+</span>
        </button>
        <div class="email-dialog__address-row">
          <code class="email-dialog__address" data-email-address>{emailLink.href.replace('mailto:', '')}</code>
          <button type="button" class="email-dialog__copy" data-copy-email>
            <LucideIcon name="Copy" />
            <span data-copy-email-label>{copyEmailLabel}</span>
          </button>
        </div>
        <div class="email-dialog__actions">
          <a class="email-dialog__action email-dialog__action--primary" href={emailLink.href}>{openEmailLabel}</a>
        </div>
      </dialog>
    ) : null}

    <section class="sidebar__language" aria-labelledby="sidebar-language-label">
      <p class="sidebar__language-label" id="sidebar-language-label">{languageLabel}</p>
      <div class="sidebar__language-box">
        {languageOptions.map((option) => (
            <a
              href={getLocalePath(option.value)}
              class:list={['sidebar__language-option', option.value === currentLocale && 'is-selected']}
              aria-current={option.value === currentLocale ? 'page' : undefined}
            >
            <span>{option.shortLabel}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</aside>
