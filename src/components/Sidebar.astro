---
import LinkIcon from './LinkIcon.astro';
import { languageOptions } from '../data/portfolio';
import type { LinkItem, PortfolioContent, SectionItem, Locale } from '../data/portfolio';

interface Props {
  profile: PortfolioContent['profile'];
  links: LinkItem[];
  sections: SectionItem[];
  languageLabel: string;
  currentLocale: Locale;
}

const { profile, links, sections, languageLabel, currentLocale } = Astro.props;
---

<aside class="sidebar" aria-label="Profile and site navigation">
  <div class="sidebar__intro">
    <div class="sidebar__identity">
      <h1>{profile.name}</h1>
      <img class="sidebar__brand-mark" src="/brand-mark.svg" alt="" aria-hidden="true" decoding="async" draggable="false" />
    </div>
    <h2 class="sidebar__role">{profile.role}</h2>
    <p class="sidebar__summary">{profile.summary}</p>
  </div>

  <nav class="sidebar__nav" aria-label="Section index">
    <ul>
      {sections.map((section, index) => (
        <li>
          <a
            href={`#${section.id}`}
            data-section-link
            data-target={section.id}
            aria-current={index === 0 ? 'true' : 'false'}
          >
            {section.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="sidebar__utility">
    <ul class="sidebar__links" aria-label="External links">
      {links.map((link) => (
        <li>
          <a href={link.href}>
            <span class="sidebar__link-icon" aria-hidden="true">
              <LinkIcon type={link.type} />
            </span>
            <span class="sidebar__link-label">{link.label}</span>
          </a>
        </li>
      ))}
    </ul>

    <section class="sidebar__language" aria-labelledby="sidebar-language-label">
      <p class="sidebar__language-label" id="sidebar-language-label">{languageLabel}</p>
      <div class="sidebar__language-box">
        {languageOptions.map((option) => (
          <a
            href={option.value === 'en' ? '/' : `/${option.value}/`}
            class:list={['sidebar__language-option', option.value === currentLocale && 'is-selected']}
            aria-current={option.value === currentLocale ? 'page' : undefined}
          >
            <span>{option.shortLabel}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</aside>
