---
import type { CollectionEntry } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import Sidebar from './Sidebar.astro';
import LucideIcon from './LucideIcon.astro';
import type { Locale, PortfolioContent } from '../data/portfolio';

interface Props {
  locale: Locale;
  content: PortfolioContent;
  blogPosts: CollectionEntry<'blog'>[];
}

const { locale, content, blogPosts } = Astro.props;
const resumeLink = content.links.find((link) => link.type === 'resume');
const copyEmailLabel = content.headings.copyEmail;
---

<div id="top"></div>
<div class="shell">
  <main
    id="main"
    class="page"
    data-copy-label={copyEmailLabel}
    data-copied-label="Copied"
    data-copy-failed-label="Copy failed"
  >
    <Sidebar
      profile={content.profile}
      links={content.links}
      sections={content.sections}
      languageLabel={content.headings.language}
      currentLocale={locale}
      copyEmailLabel={content.headings.copyEmail}
      openEmailLabel={content.headings.openEmail}
      themeLabels={{ system: content.headings.themeSystem, light: content.headings.themeLight, dark: content.headings.themeDark }}
      blogPosts={blogPosts}
    />

    <div class="content">
      <section class="content-section intro-section" id="intro" data-section>
        {content.profile.intro.map((paragraph) => (
          <p class="intro-copy intro-text">{paragraph}</p>
        ))}

        {resumeLink ? (
          <div class="intro-actions">
            <a class="text-button" href={resumeLink.href} target="_blank" rel="noopener noreferrer">
              <span>{content.headings.resumeCta}</span>
              <LucideIcon name="ArrowUpRight" />
            </a>
          </div>
        ) : null}
      </section>

      <section class="content-section" id="experience" data-section>
        <div class="section-header">
          <h2 class="section-heading">{content.headings.experience}</h2>
        </div>

        <div class="experience-list">
          {content.experience.map((item) => (
            <article class="experience-item">
              <p class="experience-item__meta">{item.period}</p>
              <div class="experience-item__content">
                <h3>
                  <span>{item.role}</span>
                  <span class="experience-item__separator" aria-hidden="true">•</span>
                  <span>{item.organization}</span>
                </h3>
                <p>{item.summary}</p>
                <ul class="badge-list" aria-label={`${item.role} technologies`}>
                  {item.stack.map((tech) => (
                    <li>{tech}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="content-section" id="projects" data-section>
        <div class="section-header">
          <h2 class="section-heading">{content.headings.projects}</h2>
        </div>

        <div class="project-list">
          {content.projects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>

        <div class="section-actions">
          <a class="text-button" href="#top">
            <LucideIcon name="ArrowUp" />
            <span>{content.headings.backToTop}</span>
          </a>
        </div>
      </section>
    </div>
  </main>
</div>

<script>
  const main = document.querySelector<HTMLElement>('main[data-copy-label]');
  const sections = [...document.querySelectorAll<HTMLElement>('[data-section]')];
  const sectionLinks = [...document.querySelectorAll<HTMLElement>('[data-section-link]')];
  const emailDialog = document.querySelector<HTMLDialogElement>('[data-email-dialog]');
  const openEmailDialogButton = document.querySelector<HTMLButtonElement>('[data-open-email-dialog]');
  const closeEmailDialogButtons = [...document.querySelectorAll<HTMLButtonElement>('[data-close-email-dialog]')];
  const copyEmailButton = document.querySelector<HTMLButtonElement>('[data-copy-email]');
  const copyEmailLabelEl = document.querySelector<HTMLElement>('[data-copy-email-label]');
  const emailAddress = document.querySelector('[data-email-address]')?.textContent?.trim() ?? '';
  const labels = {
    copy: main?.dataset.copyLabel ?? 'Copy',
    copied: main?.dataset.copiedLabel ?? 'Copied',
    failed: main?.dataset.copyFailedLabel ?? 'Copy failed',
  };

  const setActiveLink = (id: string) => {
    for (const link of sectionLinks) {
      link.setAttribute('aria-current', link.dataset.target === id ? 'true' : 'false');
    }
  };

  // cache offsets; invalidate on resize
  let offsets: Array<{ id: string; top: number }> = [];
  const recomputeOffsets = () => {
    offsets = sections.map((section) => ({ id: section.id, top: section.offsetTop }));
  };

  let ticking = false;
  const updateActiveSection = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const marker = window.scrollY + window.innerHeight * 0.28;
      let active = offsets[0];
      for (const entry of offsets) {
        if (entry.top <= marker) active = entry;
      }
      const nearBottom = window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 24;
      if (nearBottom) active = offsets.at(-1) ?? active;
      if (active?.id) setActiveLink(active.id);
      ticking = false;
    });
  };

  recomputeOffsets();
  updateActiveSection();
  window.addEventListener('scroll', updateActiveSection, { passive: true });
  window.addEventListener(
    'resize',
    () => {
      recomputeOffsets();
      updateActiveSection();
    },
    { passive: true },
  );

  let copyResetTimer = 0;
  const setCopyLabel = (value: string) => {
    if (!copyEmailLabelEl) return;
    copyEmailLabelEl.textContent = value;
    if (value === labels.copied) {
      copyEmailButton?.classList.add('is-copied');
    }
    window.clearTimeout(copyResetTimer);
    copyResetTimer = window.setTimeout(() => {
      copyEmailLabelEl.textContent = labels.copy;
      copyEmailButton?.classList.remove('is-copied');
    }, 1800);
  };

  const copyEmailToClipboard = async () => {
    if (!emailAddress) return;
    try {
      await navigator.clipboard.writeText(emailAddress);
      setCopyLabel(labels.copied);
    } catch {
      const textArea = document.createElement('textarea');
      textArea.value = emailAddress;
      textArea.setAttribute('readonly', '');
      textArea.style.position = 'absolute';
      textArea.style.left = '-9999px';
      document.body.appendChild(textArea);
      textArea.select();
      try {
        document.execCommand('copy');
        setCopyLabel(labels.copied);
      } catch {
        setCopyLabel(labels.failed);
      } finally {
        textArea.remove();
      }
    }
  };

  const lockScroll = () => document.documentElement.classList.add('has-dialog-open');
  const unlockScroll = () => document.documentElement.classList.remove('has-dialog-open');

  openEmailDialogButton?.addEventListener('click', () => {
    if (!emailDialog || typeof emailDialog.showModal !== 'function') {
      if (emailAddress) window.location.href = `mailto:${emailAddress}`;
      return;
    }
    lockScroll();
    emailDialog.showModal();
  });

  closeEmailDialogButtons.forEach((button) => {
    button.addEventListener('click', () => emailDialog?.close());
  });

  copyEmailButton?.addEventListener('click', copyEmailToClipboard);

  // Close on backdrop click
  emailDialog?.addEventListener('click', (event) => {
    const bounds = emailDialog.getBoundingClientRect();
    const isBackdropClick =
      event.clientX < bounds.left ||
      event.clientX > bounds.right ||
      event.clientY < bounds.top ||
      event.clientY > bounds.bottom;
    if (isBackdropClick) emailDialog.close();
  });

  // Unlock scroll when dialog closes (any method: Escape, close button, backdrop)
  emailDialog?.addEventListener('close', () => {
    unlockScroll();
  });

  // ── Scroll-reveal for cards and items ──────────────────────────
  const revealTargets = document.querySelectorAll<HTMLElement>(
    '.experience-item, .project-card',
  );

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion && revealTargets.length > 0) {
    // Group by parent list so stagger resets per section
    const groups = new Map<Element | null, HTMLElement[]>();
    revealTargets.forEach((el) => {
      const parent = el.parentElement;
      if (!groups.has(parent)) groups.set(parent, []);
      groups.get(parent)!.push(el);
    });

    groups.forEach((items) => {
      items.forEach((el, i) => {
        el.classList.add('reveal');
        el.style.transitionDelay = `${i * 60}ms`;
      });
    });

    const revealObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
            // Clear stagger delay after reveal + transition completes
            const delay = parseFloat(el.style.transitionDelay) || 0;
            setTimeout(() => { el.style.transitionDelay = ''; }, delay + 450);
          }
        }
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
    );

    revealTargets.forEach((el) => revealObserver.observe(el));
  }
</script>
